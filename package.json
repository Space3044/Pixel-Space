{
  "name": "imgbed",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler pages dev",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "test": "node --import=tsx tests/run-tests.mjs",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.functions.json --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply pixel-space --local",
    "db:migrate:remote": "wrangler d1 migrations apply pixel-space --remote"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "exifr": "^7.1.3",
    "justified-layout": "^4.1.0",
    "maplibre-gl": "^5.24.0",
    "three": "^0.184.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260518.1",
    "@types/node": "^25.6.2",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^5.2.0",
    "agent-ui-annotation": "0.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0",
    "wrangler": "^4.92.0"
  }
}
